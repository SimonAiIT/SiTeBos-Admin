# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# N8N Webhook for retrieving owner keys
N8N_KEY_FETCHER_WEBHOOK="https://prod.workflow.trinai.it/webhook/2fa70acb-4313-42a7-9e3b-4eea84ff8178"

# GitHub Tokens for double repository structure
GITHUB_TOKEN_SITEBOS_STRUCTURE="ghp_xxxx_structure_repo_token"
GITHUB_TOKEN_SITEBOS_ADMIN="ghp_xxxx_admin_repo_token"

# MongoDB Database URI
MONGO_URI="mongodb+srv://..."

APP_URL="MY_APP_URL"

