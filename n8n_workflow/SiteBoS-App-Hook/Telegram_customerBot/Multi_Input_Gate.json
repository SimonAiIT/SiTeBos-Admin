    {
      "parameters": {
        "jsCode": "// NODO: Find_Lowest_Content\n// VERSIONE: 1.2 - Nested Structure Fix\n\nconst input = $input.first().json;\n\n// 1. Puntiamo al percorso corretto: Memory[0].messages\nconst messages = input.Memory?.[0]?.messages;\n\n// Validazione\nif (!messages || !Array.isArray(messages)) {\n  return [{ json: { lowest_content: null, error: \"Array messaggi non trovato nel percorso Memory[0].messages\" } }];\n}\n\n// 2. Ricerca del valore minimo\nlet lowestValue = Infinity;\n\nfor (const msg of messages) {\n  // Estraiamo il valore da kwargs.content (come si vede dal tuo JSON)\n  const rawVal = msg.kwargs?.content;\n\n  if (rawVal !== undefined && rawVal !== null) {\n    const currentNum = parseInt(rawVal);\n    \n    // Confronto numerico\n    if (!isNaN(currentNum) && currentNum < lowestValue) {\n      lowestValue = currentNum;\n    }\n  }\n}\n\n// 3. Output\nreturn [{\n  json: {\n    lowest_content: lowestValue === Infinity ? null : lowestValue\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1008,
