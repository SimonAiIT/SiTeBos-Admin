    {
      "parameters": {
        "jsCode": "// NODO: Adaptive_Item_Counter\n// VERSIONE: 2.1 (Fix per struttura nidificata LangChain)\n\nconst item = $input.first().json;\n\n// 1. Accediamo al pacchetto di messaggi (Memory[0])\nconst aggregatedPackage = item.Memory?.[0];\n\n// 2. Recuperiamo il conteggio\n// Usiamo messagesCount se presente, altrimenti contiamo la lunghezza dell'array\nlet messageCount = 0;\n\nif (aggregatedPackage) {\n    if (aggregatedPackage.messagesCount !== undefined) {\n        messageCount = aggregatedPackage.messagesCount;\n    } else if (Array.isArray(aggregatedPackage.messages)) {\n        messageCount = aggregatedPackage.messages.length;\n    }\n}\n\n// --- Output pulito per i nodi successivi ---\nreturn [{ \n    json: { \n        itemCount: messageCount \n    } \n}];"
      },
      "id": "eeaacbea-63c3-4252-8dba-acdbc8781143",
      "name": "Adaptive_Item_Counter",
