      "parameters": {
        "jsCode": "// 1. Estrazione variabili\nconst item = $json;\nconst fullText = item.Operator_request?.message?.text || \"\";\nconst inviteCodeSent = fullText.split(' ')[1]; // \"/start INV-...\"\nconst currentChatId = item.Operator_request?.message?.chat?.id;\n\n// 2. Accesso agli operatori\nlet operators = item.owner_data?.operators || [];\nlet operatorsList = Array.isArray(operators) ? operators : (operators.operators || []);\n\n// 3. Ricerca e Aggiornamento\nlet matchedOperator = null;\nconst updatedOperators = operatorsList.map(op => {\n  if (op.invitation_code === inviteCodeSent) {\n    matchedOperator = { \n      ...op, \n      OperatorChatID: parseInt(currentChatId), // Forza Int32\n      status: \"ACTIVE\" \n    };\n    return matchedOperator;\n  }\n  return op;\n});\n\n// 4. Restituzione oggetto aggiornato\nreturn {\n  ...item,\n  owner_data: {\n    ...item.owner_data,\n    operators: updatedOperators // Array con ChatID aggiornato\n  },\n  authorized_operator: matchedOperator || null,\n  is_valid_invite: !!matchedOperator\n};"
      },
      "type": "n8n-nodes-base.code",
