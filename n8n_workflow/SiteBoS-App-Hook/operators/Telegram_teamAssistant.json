    {
      "parameters": {
        "jsCode": "const item = $json;\nconst original = $node[\"PrepareRequest\"].json;\nconst owner = item.owner_data || {}; \nconst baseUrl = original.UrlMiniApp;\nconst isCallback = !!original.Operator_request.callback_query;\nconst chatId = isCallback ? original.Operator_request.callback_query.message.chat.id : original.Operator_request.message.chat.id;\nconst userMsgId = isCallback ? original.Operator_request.callback_query.message.message_id : original.Operator_request.message.message_id;\nconst messageIdToEdit = isCallback ? userMsgId : userMsgId - 1; \nconst credits = owner.credits_balance || 0;\n\n// --- LOGICA ASH ---\nfunction generateSignature(str, key) {\n    let hash = 0; const combined = str + key;\n    for (let i = 0; i < combined.length; i++) {\n        hash = ((hash << 5) - hash) + combined.charCodeAt(i);\n        hash = hash & hash; \n    }\n    return Math.abs(hash).toString(16);\n}\n\nconst SECRET_KEY = 'TrinAI-Autorize-Transaction-2=2&';\nconst ts = Date.now().toString();\nconst webhookId = \"ef4aece4-9ec0-4026-a7a7-328562bcbdf6\"; \nconst ownerId = owner.chat_id || owner.user_id;\nconst payloadASH = `${ownerId}|${chatId}|${ts}|${webhookId}`;\nconst ash = `${Buffer.from(payloadASH).toString('base64')}.${generateSignature(payloadASH, SECRET_KEY)}`;\n\nconst buttons = [\n    [{ text: \"📋 Missioni & Task Attivi\", web_app: { url: `${baseUrl}operators/operator_tasks.html?ash=${ash}&msg_id=${messageIdToEdit}` } }],\n    [{ text: \"🧠 Analisi e Percorso Personale\", web_app: { url: `${baseUrl}softskill/index.html?ash=${ash}&msg_id=${messageIdToEdit}` } }],\n    [\n        { text: \"📦 Ordini\", web_app: { url: `${baseUrl}orders-manager.html?ash=${ash}&msg_id=${messageIdToEdit}` } },\n        { text: \"📝 Preventivi\", web_app: { url: `${baseUrl}preventivi.html?ash=${ash}&msg_id=${messageIdToEdit}` } }\n    ],\n    [\n        { text: \"🤝 Supporto Hub\", web_app: { url: `${baseUrl}support_hub.html?ash=${ash}&msg_id=${messageIdToEdit}` } },\n        { text: \"🛠️ Magazzino\", web_app: { url: `${baseUrl}new-insert.html?ash=${ash}&msg_id=${messageIdToEdit}` } }\n    ],\n    [\n        { text: \"🛡️ SuperVisor\", web_app: { url: `${baseUrl}operators/catalog.html?ash=${ash}&msg_id=${messageIdToEdit}` } }, \n        { text: \"📊 Performance\", callback_data: \"op_stats\" }\n    ],\n    [\n        { text: \"🔄 Sincronizza Sistema\", callback_data: \"open_agent_control_center\" }\n    ]\n];\n\nreturn [{\n    json: {\n        telegramApiPayload: {\n            method: \"editMessageText\",\n            chat_id: chatId,\n            message_id: messageIdToEdit,\n            text: `⚙️ <b>SiteBoS Operator KeyBoard</b>\\n━━━━━━━━━━━━━━━━━━━━\\n🏢 <b>${(owner.ragione_sociale || 'PRIVATE_TENANT').toUpperCase()}</b>\\n👤 OPERATORE: <b>${owner.name || ''} ${owner.surname || ''}</b>\\n🔋 RESIDUO AZIONI: <b>${credits}</b>\\n━━━━━━━━━━━━━━━━━━━━\\n🔐 <b>PROTOCOLLO PRIVACY</b>\\nChat disabilitata per minimizzazione dati. Messaggio rimosso.`,\n            parse_mode: \"HTML\",\n            reply_markup: { inline_keyboard: buttons }\n        }\n    }\n}];"
