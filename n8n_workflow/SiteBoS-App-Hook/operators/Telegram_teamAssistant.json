    {
      "parameters": {
        "jsCode": "// ═══════════════════════════════════════════════════════════════\n// NODO: Prepare Edit Payload (Data Minimization Mode)\n// ═══════════════════════════════════════════════════════════════\n\nconst owner = $node[\"Owner\"].json.owner_data;\nconst original = $node[\"PrepareRequest\"].json;\n\nconst chatId = original.Operator_request.message.chat.id;\nconst userMsgId = original.Operator_request.message.message_id;\nconst baseUrl = original.UrlMiniApp;\nconst msgIdToEdit = userMsgId - 1;\n\n// --- GENERAZIONE ASH ---\nfunction generateSignature(str, key) {\n    let hash = 0; const combined = str + key;\n    for (let i = 0; i < combined.length; i++) {\n        const char = combined.charCodeAt(i);\n        hash = ((hash << 5) - hash) + char; hash = hash & hash; \n    }\n    return Math.abs(hash).toString(16);\n}\n\nconst SECRET_KEY = 'TrinAI-Autorize-Transaction-2=2&';\nconst WEBHOOK_ID = 'ef4aece4-9ec0-4026-a7a7-328562bcbdf6';\nconst timestamp = Date.now().toString();\nconst ownerChatId = owner.chat_id || owner.user_id;\n\nconst ashPayload = `${ownerChatId}|${chatId}|${timestamp}|${WEBHOOK_ID}`;\nconst signature = generateSignature(ashPayload, SECRET_KEY);\nconst ash = `${Buffer.from(ashPayload).toString('base64')}.${signature}`;\n\nconst urlDashboard = `${baseUrl}operators/operator_onboarding.html?ash=${ash}`;\n\n// --- PAYLOAD PER EDIT ---\nreturn [{\n    json: {\n        telegramApiPayload: {\n            method: \"editMessageText\",\n            chat_id: chatId,\n            message_id: msgIdToEdit,\n            text: `⚠️ <b>SISTEMA DI SOLA OPERATIVITÀ</b>\\n━━━━━━━━━━━━━━━━━━━━\\nIn conformità con le policy di <b>minimizzazione dei dati</b>, la chat testuale è disabilitata.\\n\\nIl tuo messaggio è stato rimosso. Utilizza esclusivamente la dashboard per operare.\\n\\n🏢 <b>${owner.ragione_sociale || \"Azienda Partner\"}</b>`,\n            parse_mode: \"HTML\",\n            reply_markup: {\n                inline_keyboard: [[{ text: \"⚙️ CONFIGURA POSTAZIONE\", web_app: { url: urlDashboard } }]]\n            }\n        }\n    }\n}];"
      },
