    {
      "parameters": {
        "jsCode": "// ═══════════════════════════════════════════════════════════════\n// NODO: System_Error_Collection_Retrieval (Final Update)\n// ═══════════════════════════════════════════════════════════════\n\nconst item = $json;\nconst chatId = item.Operator_request?.message?.chat?.id || item.body?.message?.chat?.id;\nconst userLang = item.Operator_request?.message?.from?.language_code || 'it';\nconst pIva = item.PartitaIva || \"NON RILEVATA\";\n\n// 1. Dizionario Multilingua\nconst t = {\n    'it': {\n        title: \"⚠️ <b>TERMINALE BLOCCATO</b>\",\n        reason: pIva === \"NON RILEVATA\" \n            ? \"Protocollo di invito mancante o non valido.\" \n            : `Nessuna autorizzazione trovata per la P.IVA: ${pIva}.`,\n        instruction: \"<b>PROCEDURA DI RIPRISTINO:</b>\\n1. Elimina questa chat (Arresta e cancella).\\n2. Clicca nuovamente sul link di invito originale ricevuto per rigenerare la sessione.\",\n        status: \"ERR_AUTH_NOT_FOUND\",\n        btn_support: \"🆘 ASSISTENZA TECNICA\"\n    },\n    'en': {\n        title: \"⚠️ <b>TERMINAL LOCKED</b>\",\n        reason: pIva === \"NON RILEVATA\" \n            ? \"Invite protocol missing or invalid.\" \n            : `No authorization found for VAT: ${pIva}.`,\n        instruction: \"<b>RESTORE PROCEDURE:</b>\\n1. Delete this chat (Stop and block).\\n2. Click the original invite link again to regenerate the session.\",\n        status: \"ERR_AUTH_NOT_FOUND\",\n        btn_support: \"🆘 TECHNICAL SUPPORT\"\n    }\n}[(userLang.includes('it') ? 'it' : 'en')];\n\nreturn [{\n    json: {\n        telegramApiPayload: {\n            method: \"sendMessage\",\n            chat_id: chatId,\n            text: `${t.title}\\n━━━━━━━━━━━━━━━━━━━━\\n📍 <b>STATO:</b> ${t.status}\\n\\n📝 <b>DETTAGLIO:</b> ${t.reason}\\n\\n⚠️ <b>AZIONE NECESSARIA:</b>\\n${t.instruction}\\n━━━━━━━━━━━━━━━━━━━━\\n<i>ID SESSIONE: ${chatId}</i>`,\n            parse_mode: \"HTML\",\n            reply_markup: {\n                inline_keyboard: [\n                    [{ text: t.btn_support, url: \"https://t.me/TrinAi_TecSupport_bot\" }]\n                ]\n            }\n        }\n    }\n}];"
      },
