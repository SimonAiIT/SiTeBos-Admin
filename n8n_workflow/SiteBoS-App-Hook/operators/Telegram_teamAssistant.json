      "parameters": {
        "jsCode": "// Estrae il testo dal messaggio\n\nconst text = $json.Operator_request?.message?.text || \"\";\n\n// Usa una Regex per catturare solo i numeri dopo \"INV-IT\"\nconst match = text.match(/INV-IT(\\d+)/);\n\n// Restituisce la partita IVA se trovata, altrimenti un valore nullo\nreturn {\n  ...$json,\n  PartitaIva: match ? match[1] : null\n};"
      },
