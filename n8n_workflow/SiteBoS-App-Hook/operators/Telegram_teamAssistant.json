    {
      "parameters": {
        "jsCode": "// ═══════════════════════════════════════════════════════════════\n// NODO: Welcome_Onboarding_Menu (ASH 4-DATI & UPDATED URL)\n// ═══════════════════════════════════════════════════════════════\n\nconst item = $json;\nconst operator = item.authorized_operator || {};\nconst owner = item.owner_data || {};\nconst baseUrl = item.UrlMiniApp; \nconst chatId = item.Operator_request?.message?.chat?.id;\nconst msg_id = item.Operator_request.message.message_id;\n\n// --- 1. GENERAZIONE FIRMA ASH (Versione 4 Dati) ---\nfunction generateSignature(str, key) {\n    let hash = 0; const combined = str + key;\n    for (let i = 0; i < combined.length; i++) {\n        const char = combined.charCodeAt(i);\n        hash = ((hash << 5) - hash) + char; hash = hash & hash; \n    }\n    return Math.abs(hash).toString(16);\n}\n\nconst SECRET_KEY = 'TrinAI-Autorize-Transaction-2=2&';\nconst WEBHOOK_ID = 'ef4aece4-9ec0-4026-a7a7-328562bcbdf6';\nconst timestamp = Date.now().toString();\n\n// Costruzione Payload a 4 dati: OWNER_ID | OPERATOR_ID | TS | WEBHOOK\nconst ownerChatId = owner.chat_id || owner.user_id;\nconst ashPayload = `${ownerChatId}|${chatId}|${timestamp}|${WEBHOOK_ID}`;\n\nconst signature = generateSignature(ashPayload, SECRET_KEY);\nconst ash = `${Buffer.from(ashPayload).toString('base64')}.${signature}`;\n\n// --- 2. CONFIGURAZIONE URL ONBOARDING SPECIFICO ---\n// Corretto come richiesto: /operators/operator_onboarding.html\nconst urlOnboarding = `${baseUrl}operators/operator_onboarding.html?ash=${ash}&msg_id=${msg_id + 1}`;\n\n// --- 3. COPYWRITING ---\nconst operatorName = operator.OperatorName || \"Operatore\";\nconst ragioneSociale = owner.ragione_sociale || \"Azienda Partner\";\n\nconst t = {\n    it: {\n        title: `🚀 <b>BENVENUTO ${operatorName.toUpperCase()}</b>`,\n        body: `Il tuo terminale è stato configurato per:\\n🏢 <b>${ragioneSociale}</b>\\n\\nIdentità verificata. Clicca il tasto sotto per completare l'onboarding tecnico.`,\n        btn_onboarding: \"⚙️ CONFIGURA POSTAZIONE\",\n        footer: \"━━━━━━━━━━━━━━━━━━━━\"\n    }\n}['it'];\n\n// --- 4. PAYLOAD TELEGRAM ---\nreturn [{\n    json: {\n        ...item,\n        telegramApiPayload: {\n            method: \"sendMessage\",\n            chat_id: chatId,\n            text: `${t.title}\\n${t.footer}\\n${t.body}\\n${t.footer}`,\n            parse_mode: \"HTML\",\n            reply_markup: {\n                inline_keyboard: [\n                    [{ text: t.btn_onboarding, web_app: { url: urlOnboarding } }]\n                ]\n            }\n        }\n    }\n}];"
      },
