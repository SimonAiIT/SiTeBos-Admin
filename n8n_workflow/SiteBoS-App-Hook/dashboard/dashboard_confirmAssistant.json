      "parameters": {
        "jsCode": "// ═══════════════════════════════════════════════════════════════\n// NODO: Prepare_Critical_Error_Message\n// DESC: Errore grave: Crediti presenti ma Stakeholder mancante\n// ═══════════════════════════════════════════════════════════════\n\nconst item = $input.first().json;\nconst owner = item.owner_data || {};\nconst chatId = owner.chat_id;\n\n// Rilevamento lingua\nconst rawLang = (owner.lenguage || 'it').toLowerCase();\nlet lang = rawLang.includes('en') ? 'en' : 'it';\n\nconst t = {\n  it: {\n    title: \"🚨 <b>ERRORE CRITICO DI SISTEMA</b>\",\n    msg: \"Si è verificata un'incongruenza grave durante la sincronizzazione del tuo profilo (Stakeholder Missing).\",\n    action: \"L'operazione è stata <b>ANNULLATA</b> e i tuoi crediti sono stati congelati per sicurezza.\\n\\nContatta immediatamente l'assistenza tecnica TrinAi fornendo il tuo ID.\",\n    btn: \"🆘 Contatta Supporto Tecnico\"\n  },\n  en: {\n    title: \"🚨 <b>CRITICAL SYSTEM ERROR</b>\",\n    msg: \"A severe inconsistency occurred while synchronizing your profile (Stakeholder Missing).\",\n    action: \"The operation has been <b>CANCELLED</b> and your credits have been frozen for safety.\\n\\nPlease contact TrinAi technical support immediately providing your ID.\",\n    btn: \"🆘 Contact Tech Support\"\n  }\n}[lang];\n\nreturn [{\n  json: {\n    telegramApiPayload: {\n      method: \"sendMessage\", // Usiamo sendMessage per creare un nuovo alert visibile\n      chat_id: chatId,\n      text: `${t.title}\\n━━━━━━━━━━━━━━━━━━━━\\n\\n${t.msg}\\n\\n${t.action}\\n\\n📍 ID: <code>${chatId}</code>`,\n      parse_mode: \"HTML\",\n      reply_markup: {\n        inline_keyboard: [\n          [{ text: t.btn, url: \"https://t.me/TrinAi_Support\" }] // O il link alla tua assistenza\n        ]\n      }\n    }\n  }\n}];"
      },
