      "parameters": {
        "jsCode": "// ═══════════════════════════════════════════════════════════════\n// NODO: Update_Credits_With_Summary\n// DESC: Sottrae 10 crediti, attiva assistente e genera summary\n// ═══════════════════════════════════════════════════════════════\n\nconst item = $input.first().json;\n\n// 1. Configurazione\nconst COSTO_GETTONE = 10;\nconst timestamp = new Date().toISOString();\nconst previousBalance = item.owner_data.credits_balance || 0;\nconst finalBalance = Math.max(0, previousBalance - COSTO_GETTONE);\n\n// 2. Aggiornamento Profili (Owner e Stakeholder)\nitem.owner_data.credits_balance = finalBalance;\nitem.owner_data.subscription_assistant = true; // Attivazione chiave\n\nif (item.stakeholder && item.stakeholder.commercial_profile) {\n    item.stakeholder.commercial_profile.credit_balance.available_credits = finalBalance;\n    item.stakeholder.commercial_profile.credit_balance.last_update = timestamp;\n    \n    if (item.stakeholder.metadata) {\n        item.stakeholder.metadata.last_updated = timestamp;\n    }\n}\n\n// 3. Creazione Transaction Summary (Struttura richiesta)\nitem.transaction_summary = {\n  model: \"assistant_activation_logic_v1\",\n  is_long_context: false,\n  usage: {\n    in: 0,  // Operazione di sistema, non consuma token LLM\n    out: 0\n  },\n  usd_cost: 0, // Costo interno in crediti\n  credits_deducted: COSTO_GETTONE,\n  previous_balance: previousBalance,\n  final_balance: finalBalance,\n  timestamp: timestamp,\n  use: \"assistant_activation\",\n  wh: \"https://prod.workflow.trinai.it/webhook/ef4aece4-9ec0-4026-a7a7-328562bcbdf6\"\n};\n\n// 4. Ritorna l'oggetto completo\nreturn [{\n    json: item\n}];"
      },
