    {
      "parameters": {
        "jsCode": "// ═══════════════════════════════════════════════════════════════\n// NODO: Prepare_Dynamic_Agent_Selection (V7.5 - Business Logic)\n// ═══════════════════════════════════════════════════════════════\n\nconst item = $input.first().json;\nconst owner = item.owner_data || {};\nconst baseUrl = item.urlMiniApp || \"https://trinaibusinessoperatingsystem.github.io/SiteBoS-MiniApp/telegram_control/\";\nconst credits = owner.credits_balance || 0;\nconst callbackQuery = item.body.callback_query || {};\n\nconst chatId = (item.body.message?.chat.id) || (callbackQuery.message?.chat.id) || owner.chat_id;\nconst messageIdToEdit = (callbackQuery.message?.message_id) || null;\n\n// --- 1. DEFINIZIONE HELPER ASH ---\nfunction generateSignature(str, key) {\n    let hash = 0; const combined = str + key;\n    for (let i = 0; i < combined.length; i++) {\n        const char = combined.charCodeAt(i);\n        hash = ((hash << 5) - hash) + char; hash = hash & hash; \n    }\n    return Math.abs(hash).toString(16);\n}\nconst SECRET_KEY = 'TrinAI-Autorize-Transaction-2=2&';\nconst ts = Date.now().toString();\nconst payloadASH = `${chatId}|${ts}|ef4aece4-9ec0-4026-a7a7-328562bcbdf6`;\nconst ash = `${Buffer.from(payloadASH).toString('base64')}.${generateSignature(payloadASH, SECRET_KEY)}`;\n\n// --- 2. PARAMETRI DI BUSINESS ---\nconst COSTO_ATTIVAZIONE_CERT = 1500;\nconst COSTO_USO_CERT = 1;\nconst URL_DASHBOARD = \"https://dashboard.trinai.it/\";\n\n// --- 3. LOCALIZZAZIONE & COPY (Dark-Tech) ---\nconst t = {\n    header: `🛠️ <b>SiteBoS Assistant KeyBord</b>`,\n    entity: `🏢 <b>${(owner.ragione_sociale || 'PRIVATE_TENANT').toUpperCase()}</b>`,\n    user: `👤 OPERATORE: <b>${owner.name} ${owner.surname}</b>`,\n    status: `📊 STATO: <b>OPERATIVO</b>`,\n    balance: `🔋 DISPONIBILITÀ: <b>${credits} CREDITI</b>`,\n    gdpr: `🔐 <b>GDPR:</b> <i>Ogni interazione viene rimossa istantaneamente dai server per garantire la totale riservatezza.</i>`\n}['it'];\n\n// --- 4. COSTRUZIONE TASTIERA DINAMICA 5x2 ---\nlet buttons = [];\n\n// RIGA 1: CERTIFICATORE & INTELLIGENCE\nlet r1 = [];\n// --- LOGICA AGENTE CERTIFICATORE (Ripristinata) ---\nconst subCert = owner.subscription_certificator;\nif (subCert === undefined || subCert === null) {\n  r1.push({ \n    text: (credits >= COSTO_ATTIVAZIONE_CERT ? \"🛡️ ATTIVA CERTIFICATORE\" : \"⚠️ RICARICA (1500)\"), \n    callback_data: \"activate_certifier\",\n    ...(credits < COSTO_ATTIVAZIONE_CERT && { url: URL_DASHBOARD })\n  });\n} else if (subCert === true) {\n  r1.push({ \n    text: (credits >= COSTO_USO_CERT ? \"🛡️ HUB CERTIFICAZIONI\" : \"⚠️ CREDITO INSUF. [Cert]\"), \n    callback_data: \"get_active\",\n    ...(credits < COSTO_USO_CERT && { url: URL_DASHBOARD })\n  });\n} else {\n  r1.push({ text: \"🛑 SOSPESO [Cert]\", url: URL_DASHBOARD });\n}\n\n// --- LOGICA INTELLIGENCE (REPORT AI) ---\nconst subIntelligence = owner.subscription_assistant; // Ex Assistente\nif (subIntelligence === true) {\n    r1.push({ text: \"📊 REPORT AI\", callback_data: \"activate_business_assistant\" });\n} else {\n    r1.push({ text: \"📊 ATTIVA INTELLIGENCE\", callback_data: \"activate_business_assistant\" });\n}\nbuttons.push(r1);\n\n// RIGA 2: TEAM HR & ASSETS\nbuttons.push([\n    { text: \"👥 TEAM HR\", callback_data: \"m_team\" },\n    { text: \"🏗️ ASSET & TOOLS\", callback_data: \"m_assets\" }\n]);\n\n// RIGA 3: MARKETING & CATALOGO (ASH)\nbuttons.push([\n    { text: \"📣 MARKETING HUB\", callback_data: \"m_mkt\" },\n    { text: \"📋 CATALOGO & PROCEDURE\", web_app: { url: `${baseUrl}catalog.html?ash=${ash}` } }\n]);\n\n// RIGA 4: LOGISTICA & ACQUISTI (ASH)\nbuttons.push([\n    { text: \"⏳ LOGISTICA TEMPO\", callback_data: \"tm_menu\" },\n    { text: \"💸 ACQUISTI AI\", web_app: { url: `${baseUrl}new-insert.html?ash=${ash}` } }\n]);\n\n// RIGA 5: SETTINGS (ASH) & RE-SYNC\nbuttons.push([\n    { text: \"⚙️ SETTINGS & API\", web_app: { url: `${baseUrl}edit_owner.html?ash=${ash}` } },\n    { text: \"🔄 RE-SYNC\", callback_data: \"open_agent_control_center\" }\n]);\n\n// --- 5. RITORNO PAYLOAD ---\nconst dashboardMessage = [\n    t.header, \"━━━━━━━━━━━━━━━━━━━━\",\n    t.entity, t.user, t.status, t.balance,\n    \"━━━━━━━━━━━━━━━━━━━━\", t.gdpr\n].join('\\n');\n\nreturn [{\n    json: {\n        ...item,\n        telegramMethod: messageIdToEdit ? \"editMessageText\" : \"sendMessage\",\n        telegramPayload: {\n            chat_id: chatId,\n            ...(messageIdToEdit && { message_id: messageIdToEdit }),\n            text: dashboardMessage,\n            parse_mode: \"HTML\",\n            reply_markup: { inline_keyboard: buttons }\n        }\n    }\n}];\n"
      },
