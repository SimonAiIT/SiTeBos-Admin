    {
      "parameters": {
        "jsCode": "// ═══════════════════════════════════════════════════════════════\n// NODO: Prepare_Dynamic_Agent_Selection (Verticale, Con Filtro Ruoli)\n// ═══════════════════════════════════════════════════════════════\nconst item = $input.first().json;\nconst owner = item.owner_data || {};\nconst baseUrl = item.urlMiniApp || \"https://telegram.trinai.it/\";\nconst credits = owner.credits_balance !== undefined ? owner.credits_balance : 600; \nconst callbackQuery = item.body.callback_query || {};\nconst chatId = (item.body.message?.chat.id) || (callbackQuery.message?.chat.id) || owner.chat_id;\nconst messageIdToEdit = (callbackQuery.message && callbackQuery.message.message_id) || null;\n\n// --- LOGICA CONDIVISA UTENTE DI TEST ---\nconst isTestUser = String(chatId) === \"2041408875\";\n\n// --- LOGICA ASH ---\nfunction generateSignature(str, key) {\n    let hash = 0; const combined = str + key;\n    for (let i = 0; i < combined.length; i++) {\n        const char = combined.charCodeAt(i);\n        hash = ((hash << 5) - hash) + char; hash = hash & hash; \n    }\n    return Math.abs(hash).toString(16);\n}\nconst SECRET_KEY = 'TrinAI-Autorize-Transaction-2=2&';\nconst ts = Date.now().toString();\nconst payloadASH = `${chatId}|${ts}|ef4aece4-9ec0-4026-a7a7-328562bcbdf6`;\nconst ash = `${Buffer.from(payloadASH).toString('base64')}.${generateSignature(payloadASH, SECRET_KEY)}`;\n\n// --- LOGICA SUPERVISOR (OUT-OF-THE-BOX & ATTIVO DI DEFAULT) ---\nconst COSTO_USO_CERT = 1;\nconst URL_DASHBOARD = \"https://dashboard.trinai.it/\";\n\nlet labelSup = \"🛡️ SuperVisor\";\nlet cbSup = \"get_active\";\nlet urlSup = null;\n\nif (credits < COSTO_USO_CERT) {\n    labelSup = \"⚠️ Credito Insufficiente\";\n    urlSup = URL_DASHBOARD;\n}\n\nconst t = {\n    header: `🛠️ <b>SiteBoS Assistant KeyBoard</b>`,\n    entity: `🏢 <b>${(owner.ragione_sociale || 'PRIVATE_TENANT').toUpperCase()}</b>`,\n    user: `👤 OPERATORE: <b>${owner.name || 'Operatore'} ${owner.surname || ''}</b>`,\n    status: `📊 STATO: <b>OPERATIVO</b>`,\n    balance: `🔋 DISPONIBILITÀ: <b>${credits} CREDITI</b>`,\n    gdpr: `🔐 <b>PROTOCOLLO SICUREZZA & PRIVACY</b>\\n<i>In conformità al GDPR (Reg. UE 2016/679) e al principio di minimizzazione dei dati, tutti i messaggi inviati a questa chat vengono rimossi ISTANTANEAMENTE per garantirne la totale riservatezza ed evitarne la conservazione sui server di Telegram.</i>`\n};\n\n// --- COSTRUZIONE DINAMICA TASTIERA (1 PULSANTE PER RIGA) ---\nconst buttons = [];\n\nbuttons.push([{ text: \"🏢 Identità Aziendale\", web_app: { url: `${baseUrl}identity_hub.html?ash=${ash}&msg=${messageIdToEdit}` } }]);\nbuttons.push([{ text: \"📋 Gestione Aziendale\", web_app: { url: `${baseUrl}catalog.html?ash=${ash}&msg=${messageIdToEdit}` } }]);\nbuttons.push([{ text: labelSup, ...(urlSup ? { url: urlSup } : { callback_data: cbSup }) }]);\nbuttons.push([{ text: \"📣 Marketing\", callback_data: \"m_mkt\" }]);\nbuttons.push([{ text: \"👥 Team\", callback_data: \"m_team\" }]);\n\nif (isTestUser) {\n    buttons.push([{ text: \"💸 Acquisti\", web_app: { url: `${baseUrl}new-insert.html?ash=${ash}&msg=${messageIdToEdit}` } }]);\n    buttons.push([{ text: \"⏳ Operazioni\", callback_data: \"tm_menu\" }]);\n    buttons.push([{ text: \"💬 Comunicazioni\", web_app: { url: `${baseUrl}comunication_hub.html?ash=${ash}&msg=${messageIdToEdit}` } }]);\n    buttons.push([{ text: \"📊 Intelligence\", callback_data: \"int_\" }]);\n}\n\nbuttons.push([{ text: \"🔄 Sync\", callback_data: \"open_agent_control_center\" }]);\n\n// Costruzione testo con andate a capo native (no double escape)\nconst formattedText = `${t.header}\n━━━━━━━━━━━━━━━━━━━━\n${t.entity}\n${t.user}\n${t.status}\n${t.balance}\n━━━━━━━━━━━━━━━━━━━━\n${t.gdpr}`;\n\nreturn [{\n    json: {\n        ...item,\n        telegramApiPayload: {\n            method: messageIdToEdit ? \"editMessageText\" : \"sendMessage\",\n            chat_id: chatId,\n            ...(messageIdToEdit && { message_id: messageIdToEdit }),\n            text: formattedText,\n            parse_mode: \"HTML\",\n            reply_markup: { inline_keyboard: buttons }\n        }\n    }\n}];"
      },
