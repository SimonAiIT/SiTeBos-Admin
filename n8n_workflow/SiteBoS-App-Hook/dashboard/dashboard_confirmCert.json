    {
      "parameters": {
        "jsCode": "// ═══════════════════════════════════════════════════════════════\n// NODO: BalanceUpdateCert\n// DESC: Sottrae 1500 crediti, attiva Certificatore e genera summary\n// ═══════════════════════════════════════════════════════════════\n\nconst item = $input.first().json;\n\n// 1. Configurazione Business\nconst COSTO_ATTIVAZIONE = 1500;\nconst timestamp = new Date().toISOString();\n\n// 2. Calcolo Saldo (Recuperato dal merge)\nconst previousBalance = item.owner_data.credits_balance || 0;\nconst finalBalance = Math.max(0, previousBalance - COSTO_ATTIVAZIONE);\n\n// 3. Aggiornamento Strutture OWNER_DATA\nitem.owner_data.credits_balance = finalBalance;\nitem.owner_data.subscription_certificator = true; // Attivazione modulo Certificatore\nitem.owner_data.last_update = timestamp;\n\n// 4. Aggiornamento STAKEHOLDER (Commercial Profile)\nif (item.stakeholder && item.stakeholder.commercial_profile) {\n    item.stakeholder.commercial_profile.credit_balance.available_credits = finalBalance;\n    item.stakeholder.commercial_profile.credit_balance.last_update = timestamp;\n    \n    if (item.stakeholder.metadata) {\n        item.stakeholder.metadata.last_updated = timestamp;\n    }\n}\n\n// 5. Generazione Transaction Summary (Audit Log)\nitem.transaction_summary = {\n  model: \"certifier_activation_logic_v2\",\n  is_long_context: false,\n  usage: { in: 0, out: 0 },\n  usd_cost: 0, \n  credits_deducted: COSTO_ATTIVAZIONE,\n  previous_balance: previousBalance,\n  final_balance: finalBalance,\n  timestamp: timestamp,\n  use: \"certifier_activation\", // Identificativo per il database\n  wh: \"https://prod.workflow.trinai.it/webhook/certifier_activation_trigger\"\n};\n\n// 6. Ritorna l'oggetto completo pronto per l'update su DB\nreturn [{ json: item }];"
