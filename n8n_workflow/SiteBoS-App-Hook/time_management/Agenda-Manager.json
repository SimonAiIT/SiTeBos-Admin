        "jsCode": "const item = $input.first().json;\nconst body = item.body || {};\nconst name = body.name || 'Nuovo';\nconst newCal = {\n    id: 'cal_' + Date.now(),\n    name: name,\n    color: '#' + Math.floor(Math.random()*16777215).toString(16).padStart(6, '0')\n};\n\n// Retrieve existing calendars from prior merge if available\nlet existingCalendars = [];\ntry {\n    const raw = $('Get Calendars For Edit').first()?.json?.calendars;\n    if (raw && typeof raw === 'string') {\n        existingCalendars = JSON.parse(raw);\n    } else if (Array.isArray(raw)) {\n        existingCalendars = raw;\n    }\n} catch(e) {}\n\nif (!existingCalendars || existingCalendars.length === 0) {\n    existingCalendars = [{ id: 'default', name: 'Personale', color: '#000000' }];\n}\n\nexistingCalendars.push(newCal);\n\nreturn [{\n    json: {\n        ...item,\n        calendars_json: JSON.stringify(existingCalendars),\n        new_calendar: newCal\n    }\n}];"
