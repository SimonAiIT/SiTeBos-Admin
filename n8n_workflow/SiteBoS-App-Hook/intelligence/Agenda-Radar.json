      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst ash = item.ash || (item.body ? item.body.ash : null);\nconst SECRET_KEY = 'TrinAI-Autorize-Transaction-2=2&';\n\nif (!ash || !ash.includes('.')) {\n    return [{ json: { isValid: false, error: \"Ash mancante\" } }];\n}\n\ntry {\n    const [encodedPayload, sigReceived] = ash.split('.');\n    const decodedPayload = Buffer.from(encodedPayload, 'base64').toString('utf-8');\n    const parts = decodedPayload.split('|');\n    if (parts.length !== 3) return [{ json: { isValid: false, error: \"Ash malformato\" } }];\n\n    const [chatId, timestamp, webhookId] = parts;\n\n    function generateSignature(str, key) {\n        let hash = 0; const combined = str + key;\n        for (let i = 0; i < combined.length; i++) {\n            const char = combined.charCodeAt(i);\n            hash = ((hash << 5) - hash) + char; hash = hash & hash; \n        }\n        return Math.abs(hash).toString(16);\n    }\n\n    const calculatedSig = generateSignature(decodedPayload, SECRET_KEY);\n    if (sigReceived !== calculatedSig) return [{ json: { isValid: false, error: \"Firma non valida\" } }];\n\n    return [{ json: { isValid: true, chatId } }];\n} catch (e) {\n    return [{ json: { isValid: false, error: \"Errore decodifica\" } }];\n}"
      },
