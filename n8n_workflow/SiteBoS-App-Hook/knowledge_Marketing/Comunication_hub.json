    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst sessions = [];\n\nitems.forEach(item => {\n    const doc = item.json;\n    if (!doc.sessionId) return;\n    \n    let customerId = doc.customer_chatid || doc.customer_id;\n    if (!customerId) {\n        const parts = doc.sessionId.split('-');\n        customerId = parts[0];\n    }\n    \n    let customerName = doc.customer_name;\n    if (!customerName && doc.lead_profile) {\n        customerName = `${doc.lead_profile.first_name || ''} ${doc.lead_profile.last_name || ''}`.trim();\n    }\n    if (!customerName) {\n        customerName = `Cliente (${customerId})`;\n    }\n    \n    let lastMessage = \"Vedi dettagli...\";\n    if (Array.isArray(doc.messages) && doc.messages.length > 0) {\n        const lastMsg = doc.messages[doc.messages.length - 1];\n        lastMessage = lastMsg.data?.content || lastMsg.kwargs?.content || lastMsg.text || lastMsg.content || lastMessage;\n    }\n    \n    let type = doc.type || \"TICKET\";\n    if (doc.sessionId.includes('prev')) {\n        type = \"PREVENTIVO\";\n    }\n    \n    sessions.push({\n        customer_id: customerId,\n        customer_name: customerName,\n        last_message: lastMessage,\n        type: type,\n        status: doc.status || (doc.closed ? \"resolved\" : \"open\"),\n        closed: doc.closed || false\n    });\n});\n\nreturn [{ json: { success: true, sessions } }];"
      },
