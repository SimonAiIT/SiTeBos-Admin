    {
      "parameters": {
        "jsCode": "/**\n * NODO: Update Stakeholder Balance (Minimal)\n */\n\nconst results = [];\n\nfor (const item of $input.all()) {\n    const data = item.json;\n    const stakeholder = data.stakeholder;\n    const summary = data.transaction_summary;\n\n    if (stakeholder && summary) {\n        // 1. Applica il saldo finale calcolato\n        stakeholder.commercial_profile.credit_balance.available_credits = summary.final_balance;\n        \n        // 2. Usa il timestamp del riepilogo per tutto\n        const ts = summary.timestamp; // Es: \"2026-03-02T17:21:41.227Z\"\n        \n        stakeholder.commercial_profile.credit_balance.last_update = ts;\n        stakeholder.commercial_profile.credit_balance.last_transaction_id = ts; // Usiamo il timestamp come ID\n        stakeholder.metadata.last_updated = ts;\n    }\n\n    results.push({\n        stakeholder_owner: stakeholder\n    });\n}\n\nreturn results;"
      },
