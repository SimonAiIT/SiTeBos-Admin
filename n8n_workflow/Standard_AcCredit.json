    {
      "parameters": {
        "jsCode": "// NODO: Balance Updater & Transaction Merger\n// VERSIONE: 2.2 - Explicit Billing Object Reconstruction\n\n// ═══════════════════════════════════════════════════════════════\n// 1. REGISTRO PREZZI CENTRALIZZATO\n// ═══════════════════════════════════════════════════════════════\nconst PRICING_REGISTRY = {\n    // --- Deploy MiniSite & DNA (500 Crediti) ---\n    \"MiniSite Production Engine\": 1000,\n    // --- Pagine Strategiche / Copywriting (250 Crediti) ---\n    \"Blog Production Engine\": 500,\n    // --- Video AI (320 Crediti) ---\n    \"Video Production\": 320,\n    // --- Immagini AI & Rigenerazioni (50 Crediti) ---\n    \"Generazione Immagine\": 50,\n    // --- Attivazione PersonalTelegramBot&Valut (50 Crediti) ---\n    \"Telegram Customer Bot\": 50,\n\n};\n\nconst DEFAULT_FALLBACK_COST = 10; \n\n// ═══════════════════════════════════════════════════════════════\n// 2. ESTRAZIONE DATI ED ELABORAZIONE DINAMICA\n// ═══════════════════════════════════════════════════════════════\nconst item = $input.first().json;\n\n// 1. Estrazione del modello da modelVersion (impostato a monte in Billing_Set)\nconst model = item.modelVersion || \"unknown_model\";\n\n// 2. Estrazione esplicita dei campi nidificati di billing_source\nconst actionUse = String(item.billing_source?.use || \"internal_call\").trim();\nconst actionWebhook = String(item.billing_source?.wh || \"https://prod.workflow.trinai.it/webhook/ef4aece4-9ec0-4026-a7a7-328562bcbdf6\").trim();\n\n// 3. Lookup del prezzo nel registro\nconst creditsToDeduct = PRICING_REGISTRY[actionUse] !== undefined \n    ? PRICING_REGISTRY[actionUse] \n    : DEFAULT_FALLBACK_COST;\n\n// --- 3. DETERMINAZIONE DEL SALDO PRECEDENTE DAL LEDGER ---\nlet currentBalance = 0;\nlet foundInLedger = false;\n\nif (item.last_message && item.last_message.data) {\n    let lastTx = {};\n    const rawData = item.last_message.data;\n    \n    try {\n        if (typeof rawData === 'string') {\n            lastTx = JSON.parse(rawData);\n        } else if (rawData.content) {\n            lastTx = JSON.parse(rawData.content);\n        } else {\n            lastTx = rawData;\n        }\n        \n        if (lastTx && lastTx.final_balance !== undefined) {\n            currentBalance = Number(lastTx.final_balance);\n            foundInLedger = true;\n        }\n    } catch (e) {\n        console.warn(\"Errore durante il parsing di last_message. Procedo con fallback.\");\n    }\n}\n\nif (!foundInLedger) {\n    currentBalance = Number(item.owner_data?.credits_balance || 0);\n}\n\n// --- 4. CALCOLO NUOVO SALDO ---\nconst newBalance = currentBalance - creditsToDeduct;\n\n// --- 5. PREPARAZIONE DELL'OUTPUT UNIFICATO ---\nconst outputItem = { ...item };\n\n// Costruzione esplicita dell'oggetto billing_source con le proprietà separate\noutputItem.transaction_summary = {\n    model: model, \n    is_long_context: false,\n    usage: {\n        in: 0,\n        out: 0,\n        units: actionUse.includes(\"image\") || actionUse.includes(\"photo\") ? 1 : 0\n    },\n    usd_cost: 0, \n    credits_deducted: creditsToDeduct,\n    previous_balance: currentBalance,\n    final_balance: newBalance,\n    timestamp: new Date().toISOString(),\n    billing_source: {\n        use: actionUse,\n        wh: actionWebhook\n    }\n};\n\n// Aggiornamento cache locale del proprietario\nif (outputItem.owner_data) {\n    outputItem.owner_data.credits_balance = newBalance;\n}\n\n// Pulizia chiavi transitorie per il DB\ndelete outputItem.billing;\ndelete outputItem.modelVersion; \ndelete outputItem.billing_source; // Rimuove l'oggetto piatto temporaneo\nif (outputItem.last_message) {\n    delete outputItem.last_message;\n}\n\nreturn [{ json: outputItem }];"
      },
